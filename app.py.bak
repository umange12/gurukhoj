# ── Auth ──────────────────────────────────────────────────────────────────────
@app.route("/")
def index():
    teachers = []
    conn = get_db()
    teachers = [dict(r) for r in conn.execute(
        "SELECT * FROM teachers WHERE is_available=1 ORDER BY rating DESC LIMIT 6").fetchall()]
    conn.close()
    return render_template("index.html", teachers=teachers)

@app.route("/login", methods=["GET","POST"])
def login():
    if request.method == "POST":
        data = request.get_json() or request.form
        email = data.get("email","").strip()
        password = sha256(data.get("password",""))
        conn = get_db()
        user = conn.execute("SELECT * FROM users WHERE email=? AND password=?",
                            (email, password)).fetchone()
        conn.close()
        if user:
            session["user_id"] = user["id"]
            session["email"] = user["email"]
            session["role"] = user["role"]
            session["name"] = user["full_name"]
            if request.is_json:
                return jsonify({"success": True, "role": user["role"], "name": user["full_name"]})
            if user["role"] == "admin": return redirect("/admin")
            if user["role"] == "teacher": return redirect("/teacher-dashboard")
            return redirect("/student-portal")
        if request.is_json:
            return jsonify({"success": False, "message": "Invalid credentials"})
        return render_template("login.html", error="Invalid email or password")
    return render_template("login.html")

@app.route("/register", methods=["GET","POST"])
def register():
    if request.method == "POST":
        data = request.get_json() or request.form
        name = data.get("full_name","").strip()
        email = data.get("email","").strip()
        password = sha256(data.get("password",""))
        try:
            conn = get_db()
            conn.execute("INSERT INTO users (full_name,email,password,role) VALUES (?,?,?,'student')",
                         (name, email, password))
            conn.commit()
            conn.close()
            if request.is_json:
                return jsonify({"success": True})
            return redirect("/login")
        except:
            if request.is_json:
                return jsonify({"success": False, "message": "Email already exists"})
            return render_template("register.html", error="Email already registered")
    return render_template("register.html")

@app.route("/logout")
def logout():
    session.clear()
    return redirect("/")

# ── Teachers ──────────────────────────────────────────────────────────────────
@app.route("/our-teachers")
def our_teachers():
    conn = get_db()
    teachers = [dict(r) for r in conn.execute(
        "SELECT * FROM teachers WHERE is_available=1 ORDER BY rating DESC").fetchall()]
    conn.close()
    return render_template("our_teachers.html", teachers=teachers)

@app.route("/teacher/<code>")
def teacher_profile(code):
    conn = get_db()
    t = conn.execute("SELECT * FROM teachers WHERE teacher_code=?", (code,)).fetchone()
    reviews = conn.execute("""SELECT tr.*, s.full_name as student_name
                           FROM teacher_ratings tr JOIN students s ON tr.student_id=s.id
                           WHERE tr.teacher_id=? ORDER BY tr.created_at DESC LIMIT 10""",
                           (t["id"],)).fetchall() if t else []
    conn.close()
    if not t: return redirect("/our-teachers")
    return render_template("teacher_profile.html", teacher=dict(t),
                           reviews=[dict(r) for r in reviews])

# ── AI APIs ───────────────────────────────────────────────────────────────────
@app.route("/api/recommend", methods=["POST"])
def api_recommend():
    d = request.get_json()
    conn = get_db()
    teachers = [dict(r) for r in conn.execute("SELECT * FROM teachers WHERE is_available=1").fetchall()]
    conn.close()
    rec = TutorRecommender(teachers)
    rf_rec = RandomForestRecommender(teachers)
    results = rec.recommend(d.get("subject",""), d.get("goal","board"), d.get("mode",""), int(d.get("budget",0)))
    rf_results = rf_rec.recommend(d.get("subject",""), d.get("goal","board"), d.get("mode",""), int(d.get("budget",0)))
    return jsonify({"success": True, "results": results, "rf_results": rf_results,
                    "rf_accuracy": rf_rec.accuracy, "algorithm": "Content-Based + Random Forest Ensemble"})

@app.route("/api/search")
def api_search():
    q = request.args.get("q","")
    conn = get_db()
    teachers = [dict(r) for r in conn.execute("SELECT * FROM teachers WHERE is_available=1").fetchall()]
    conn.close()
    ranker = SmartSearchRanker(teachers)
    results = ranker.search(q)
    return jsonify({"success": True, "results": results[:8]})

@app.route("/api/chatbot", methods=["POST"])
def api_chatbot():
    msg = request.get_json().get("message","")
    conn = get_db()
    teachers = [dict(r) for r in conn.execute("SELECT * FROM teachers ORDER BY rating DESC").fetchall()]
    conn.close()
    bot = EduBotNLP(teachers)
    return jsonify({"success": True, "response": bot.respond(msg)})

@app.route("/api/predict", methods=["POST"])
def api_predict():
    d = request.get_json()
    scores = [float(x) for x in d.get("scores",[]) if x != ""]
    if not scores:
        return jsonify({"success": False, "message": "No scores provided"})
    pp = PerformancePredictor()
    result = pp.predict_next(scores)
    if "user_id" in session and d.get("student_id"):
        conn = get_db()
        conn.execute("""INSERT INTO ai_predictions (student_id,subject,input_scores,predicted_score,trend,confidence)
                     VALUES (?,?,?,?,?,?)""",
                     (d["student_id"], d.get("subject","General"), json.dumps(scores),
                      result["predicted"], result["trend"], result["confidence"]))
        conn.commit()
        conn.close()
    return jsonify({"success": True, **result})

@app.route("/api/rf-model-stats")
def rf_model_stats():
    conn = get_db()
    teachers = [dict(r) for r in conn.execute("SELECT * FROM teachers").fetchall()]
    conn.close()
    rf = RandomForestRecommender(teachers)
    return jsonify(rf.get_model_stats())

# ── Student Portal ────────────────────────────────────────────────────────────
@app.route("/student-portal")
def student_portal():
    if session.get("role") not in ["student","admin"]:
        return redirect("/login")
    conn = get_db()
    student = conn.execute("SELECT * FROM students WHERE user_id=?",
                           (session["user_id"],)).fetchone()
    if not student:
        conn.close()
        return render_template("student_portal.html", student=None)
    s = dict(student)
    tests = [dict(r) for r in conn.execute(
        "SELECT * FROM tests WHERE student_id=? ORDER BY test_date DESC LIMIT 20", (s["id"],)).fetchall()]
    attendance = conn.execute("""SELECT COUNT(*) as total,
                              SUM(CASE WHEN status='Present' THEN 1 ELSE 0 END) as present
                              FROM attendance WHERE student_id=?""", (s["id"],)).fetchone()
    payments = [dict(r) for r in conn.execute(
        "SELECT * FROM payments WHERE student_id=? ORDER BY created_at DESC LIMIT 6", (s["id"],)).fetchall()]
    teacher = None
    if s["assigned_teacher_id"]:
        t = conn.execute("SELECT * FROM teachers WHERE id=?", (s["assigned_teacher_id"],)).fetchone()
        if t: teacher = dict(t)
    conn.close()
    att_pct = round((attendance["present"]/attendance["total"])*100) if attendance["total"] else 0
    return render_template("student_portal.html", student=s, tests=tests, attendance=attendance,
                           att_pct=att_pct, payments=payments, teacher=teacher)

# ── Teacher Dashboard ─────────────────────────────────────────────────────────
@app.route("/teacher-dashboard")
def teacher_dashboard():
    if session.get("role") not in ["teacher","admin"]:
        return redirect("/login")
    conn = get_db()
    teacher = conn.execute("SELECT * FROM teachers WHERE email=?",
                           (session.get("email"),)).fetchone()
    if not teacher:
        conn.close()
        return render_template("teacher_dashboard.html", teacher=None, students=[])
    t = dict(teacher)
    students = [dict(r) for r in conn.execute(
        "SELECT * FROM students WHERE assigned_teacher_id=? AND is_active=1", (t["id"],)).fetchall()]
    conn.close()
    return render_template("teacher_dashboard.html", teacher=t, students=students)

@app.route("/api/add-test", methods=["POST"])
def add_test():
    if session.get("role") not in ["teacher","admin"]:
        return jsonify({"success": False})
    d = request.get_json()
    conn = get_db()
    marks = int(d.get("marks",0))
    total = int(d.get("total",100))
    pct = round((marks/total)*100, 1)
    grade = "A+" if pct>=90 else "A" if pct>=80 else "B+" if pct>=70 else "B" if pct>=60 else "C"
    conn.execute("""INSERT INTO tests (student_id,teacher_id,subject,test_date,marks_obtained,total_marks,percentage,grade,remarks)
                 VALUES (?,?,?,?,?,?,?,?,?)""",
                 (d["student_id"], d["teacher_id"], d["subject"], d["date"], marks, total, pct, grade, d.get("remarks","")))
    conn.commit()
    conn.close()
    return jsonify({"success": True, "grade": grade, "percentage": pct})

@app.route("/api/mark-attendance", methods=["POST"])
def mark_attendance():
    if session.get("role") not in ["teacher","admin"]:
        return jsonify({"success": False})
    d = request.get_json()
    conn = get_db()
    for item in d.get("attendance",[]):
        conn.execute("""INSERT OR REPLACE INTO attendance (student_id,teacher_id,date,status,subject)
                     VALUES (?,?,?,?,?)""",
                     (item["student_id"], d["teacher_id"], d["date"], item["status"], d.get("subject","")))
    conn.commit()
    conn.close()
    return jsonify({"success": True})

# ── Admin ─────────────────────────────────────────────────────────────────────
@app.route("/admin")
def admin():
    if session.get("role") != "admin":
        return redirect("/login")
    conn = get_db()
    teachers = [dict(r) for r in conn.execute("SELECT * FROM teachers ORDER BY id").fetchall()]
    students = [dict(r) for r in conn.execute("SELECT * FROM students ORDER BY id").fetchall()]
    stats = {
        "teachers": conn.execute("SELECT COUNT(*) FROM teachers").fetchone()[0],
        "students": conn.execute("SELECT COUNT(*) FROM students").fetchone()[0],
        "pending_payments": conn.execute("SELECT COUNT(*) FROM payments WHERE status='Pending'").fetchone()[0],
        "tests_today": conn.execute("SELECT COUNT(*) FROM tests WHERE test_date=date('now')").fetchone()[0],
    }
    conn.close()
    return render_template("admin.html", teachers=teachers, students=students, stats=stats)

@app.route("/api/admin/teacher", methods=["POST","PUT","DELETE"])
def admin_teacher():
    if session.get("role") != "admin":
        return jsonify({"success": False, "message": "Unauthorized"})
    d = request.get_json()
    conn = get_db()
    if request.method == "POST":
        code = f"T{conn.execute('SELECT COUNT(*)+100 FROM teachers').fetchone()[0]}"
        conn.execute("""INSERT INTO teachers (teacher_code,full_name,email,phone,subjects,area,
                     teaching_mode,monthly_fee,experience_years,education,about)
                     VALUES (?,?,?,?,?,?,?,?,?,?,?)""",
                     (code, d["full_name"], d["email"], d["phone"], d["subjects"], d["area"],
                      d.get("mode","Both"), int(d.get("fee",1500)), int(d.get("exp",1)),
                      d.get("education",""), d.get("about","")))
        conn.commit(); conn.close()
        return jsonify({"success": True, "message": "Teacher added!"})
    if request.method == "DELETE":
        conn.execute("DELETE FROM teachers WHERE id=?", (d["id"],))
        conn.commit(); conn.close()
        return jsonify({"success": True})
    conn.close()
    return jsonify({"success": False})

@app.route("/api/admin/update-payment", methods=["POST"])
def update_payment():
    if session.get("role") != "admin": return jsonify({"success": False})
    d = request.get_json()
    conn = get_db()
    conn.execute("UPDATE payments SET status='Paid', paid_date=date('now') WHERE id=?", (d["id"],))
    conn.commit(); conn.close()
    return jsonify({"success": True})

@app.route("/api/rate-teacher", methods=["POST"])
def rate_teacher():
    d = request.get_json()
    conn = get_db()
    conn.execute("""INSERT OR REPLACE INTO teacher_ratings (teacher_id,student_id,rating,review)
                 VALUES (?,?,?,?)""",
                 (d["teacher_id"], d.get("student_id",1), d["rating"], d.get("review","")))
    avg = conn.execute("SELECT AVG(rating) FROM teacher_ratings WHERE teacher_id=?",
                       (d["teacher_id"],)).fetchone()[0]
    cnt = conn.execute("SELECT COUNT(*) FROM teacher_ratings WHERE teacher_id=?",
                       (d["teacher_id"],)).fetchone()[0]
    conn.execute("UPDATE teachers SET rating=?, total_reviews=? WHERE id=?",
                 (round(avg,1), cnt, d["teacher_id"]))
    conn.commit(); conn.close()
    return jsonify({"success": True, "new_rating": round(avg,1)})

if __name__ == "__main__":
    if not os.path.exists(DB):
        init_db()
    else:
        conn = get_db()
        if conn.execute("SELECT COUNT(*) FROM teachers").fetchone()[0] == 0:
            conn.close()
            init_db()
        else:
            conn.close()
    app.run(debug=True, port=5000)
